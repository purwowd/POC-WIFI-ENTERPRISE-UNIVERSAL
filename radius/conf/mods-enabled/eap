eap {
	default_eap_type = sim
	timer_expire     = 60
	ignore_unknown_eap_types = no
	cisco_accounting_username_bug = no
	max_sessions = ${max_requests}

	# SIM-only probe mode. Do not load PEAP/TTLS/MSCHAPv2 here; if Android
	# cannot use SIM credentials, the run should fail clearly instead of
	# falling back to the manual PEAP UI path.
	sim {
	}
}

